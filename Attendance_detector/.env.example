# Copy to ".env" for local development (never commit the real .env).

# Required: a free Hugging Face access token (read scope is enough).
# Create one at https://huggingface.co/settings/tokens
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: override the vision-language model.
# Must be a vision (image-capable) model served by a provider enabled on your
# HF account. Verify availability at https://huggingface.co/settings/inference-providers
# Known-good alternatives: Qwen/Qwen3-VL-30B-A3B-Instruct, Qwen/Qwen2.5-VL-72B-Instruct,
# google/gemma-3-27b-it, meta-llama/Llama-4-Scout-17B-16E-Instruct
HF_MODEL=Qwen/Qwen3-VL-8B-Instruct
